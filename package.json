{
  "name": "agents-camp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A pixel-art camp where multiple coding-agent harnesses appear as walkable characters.",
  "scripts": {
    "dev": "concurrently -n web,agents -c cyan,magenta \"vite\" \"pnpm dev:server\"",
    "dev:web": "vite",
    "dev:server": "tsx watch server/index.ts",
    "server": "tsx server/index.ts",
    "build": "tsc && vite build",
    "check": "pnpm build && pnpm exec tsc -p tsconfig.server.json && pnpm check:assets",
    "check:assets": "tsx scripts/check-assets.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.152",
    "phaser": "^4.1.0",
    "solid-js": "^1.9.13",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-solid": "^2.11.12"
  }
}
