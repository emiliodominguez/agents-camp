# Copy to .env to configure Agents Camp harnesses.
# If a villager's selected harness is unavailable, that villager falls back to
# canned "mock" replies so the pipeline still works.

# Default harness for new/legacy villagers: claude or codex.
# AGENT_HARNESS=claude

# Claude harness: recommended path uses your Claude subscription, no metered API key.
# One-time: run `claude setup-token`, copy the token it prints, paste it here.
# The Agent SDK reads this automatically; usage draws from your Claude plan.
CLAUDE_CODE_OAUTH_TOKEN=

# Claude harness alternative — a standalone Anthropic API key (metered).
# ANTHROPIC_API_KEY=sk-ant-...

# Optional Claude model (default: claude-sonnet-4-6).
# CLAUDE_AGENT_MODEL=claude-sonnet-4-6

# Codex harness: uses the local `codex` CLI by default.
# CODEX_BIN=codex
# CODEX_AGENT_MODEL=gpt-5

# Optional: backend WebSocket port (default: 8787). Vite proxies /agents to it.
# AGENT_PORT=8787
