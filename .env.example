# Copy to .env to run the village agents on real Claude.
# Without either credential below, the backend serves canned "mock" replies so
# the pipeline still works.

# RECOMMENDED — run on your Claude subscription, no metered API key.
# One-time: run `claude setup-token`, copy the token it prints, paste it here.
# The Agent SDK reads this automatically; usage draws from your Claude plan.
CLAUDE_CODE_OAUTH_TOKEN=

# ALTERNATIVE — a standalone Anthropic API key (metered, pay-as-you-go).
# Only needed if you are not using the subscription token above.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: model for live agent sessions (default: claude-sonnet-4-6).
# AGENT_MODEL=claude-sonnet-4-6

# Optional: backend WebSocket port (default: 8787). Vite proxies /agents to it.
# AGENT_PORT=8787
